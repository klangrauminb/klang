---
const navItems = [
  { href: '/', label: 'Startseite', ariaLabel: 'Zur Startseite' },
  { href: '/behandlung-kosten/', label: 'Behandlung & Kosten', ariaLabel: 'Zu Behandlung & Kosten' },
  { href: '/ueber-mich/', label: 'Über mich', ariaLabel: 'Über Eva Brandt' },
  { href: '/kontakt/', label: 'Kontakt', ariaLabel: 'Zur Kontaktseite' },
];

const currentPath = Astro.url.pathname;
---

<header class="sticky top-0 z-40 bg-[#9dae9f] backdrop-blur-sm border-b border-[#e7e8dc]/20">
  <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex items-center justify-between h-24 md:h-28">
      <!-- Logo + Brand Name -->
      <a 
        href="/" 
        class="flex items-center gap-6 hover:opacity-80 transition-opacity"
        aria-label="Klangraum in Balance - Zur Startseite"
      >
        <img 
          src="/logo2.png" 
          alt="Klangraum in Balance Logo" 
          class="h-12 md:h-16 w-auto rounded-lg"
          width="512"
          height="512"
        />
        <span class="text-xl md:text-xl lg:text-4xl font-normal text-klang-cream tracking-wide uppercase whitespace-nowrap">
          KLANGRAUM IN BALANCE
        </span>
      </a>
      
      <!-- Desktop Navigation -->
      <nav class="hidden md:block" aria-label="Hauptnavigation">
        <ul class="flex items-center space-x-6">
          {navItems.map((item) => {
            const isActive = currentPath === item.href || currentPath === item.href.slice(0, -1);
            return (
              <li>
                <a 
                  href={item.href}
                  class={`text-xs font-medium transition-colors hover:text-klang-cream/70 ${
                    isActive 
                      ? 'text-klang-cream border-b-2 border-klang-cream pb-1' 
                      : 'text-klang-cream/80'
                  }`}
                  aria-label={item.ariaLabel}
                  aria-current={isActive ? 'page' : undefined}
                >
                  {item.label}
                </a>
              </li>
            );
          })}
        </ul>
      </nav>
      
      <!-- Mobile Menu Button -->
      <button
        type="button"
        id="mobile-menu-button"
        class="md:hidden p-3 rounded-md text-klang-cream hover:bg-klang-cream/10 transition-colors focus:outline-none focus:ring-2 focus:ring-klang-green/50 min-w-[44px] min-h-[44px] flex items-center justify-center"
        aria-label="Menü öffnen"
        aria-expanded="false"
        aria-controls="mobile-menu"
      >
        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
        </svg>
      </button>
    </div>
  </div>
  
  <!-- Mobile Menu -->
  <div 
    id="mobile-menu" 
    class="md:hidden hidden bg-[#9dae9f] border-t border-[#e7e8dc]/20"
    aria-label="Mobile Navigation"
  >
    <nav class="max-w-6xl mx-auto px-4 py-4">
      <ul class="space-y-3">
        {navItems.map((item) => {
          const isActive = currentPath === item.href || currentPath === item.href.slice(0, -1);
          return (
            <li>
              <a 
                href={item.href}
                class={`block py-2 text-base font-medium transition-colors ${
                  isActive 
                    ? 'text-klang-cream font-semibold' 
                    : 'text-klang-cream/80 hover:text-klang-cream'
                }`}
                aria-label={item.ariaLabel}
                aria-current={isActive ? 'page' : undefined}
              >
                {item.label}
              </a>
            </li>
          );
        })}
      </ul>
    </nav>
  </div>
</header>

<script is:inline>
  // Mobile Menu Toggle
  (function() {
    const button = document.getElementById('mobile-menu-button');
    const menu = document.getElementById('mobile-menu');
    
    if (button && menu) {
      button.addEventListener('click', () => {
        const isExpanded = button.getAttribute('aria-expanded') === 'true';
        button.setAttribute('aria-expanded', String(!isExpanded));
        menu.classList.toggle('hidden');
        
        // Update aria-label
        button.setAttribute('aria-label', isExpanded ? 'Menü öffnen' : 'Menü schließen');
        
        // Update icon
        const svg = button.querySelector('svg');
        if (svg) {
          if (isExpanded) {
            svg.innerHTML = '<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />';
          } else {
            svg.innerHTML = '<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />';
          }
        }
      });
    }
  })();
</script>
